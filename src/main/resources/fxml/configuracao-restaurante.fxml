<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifpb.ads.foodjava.controller.configuracaoInicial.ConfiguracaoRestauranteController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="10" style="-fx-background-color: #34D399;">
         <padding>
            <Insets bottom="15" left="25" right="25" top="15" />
         </padding>

         <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="FoodJava">
            <font>
               <Font size="28" />
            </font>
         </Label>

         <Region HBox.hgrow="ALWAYS" />
      </HBox>
   </top>

   <center>
      <VBox alignment="TOP_CENTER" spacing="18" style="-fx-background-color: #F7F4EE;">
         <padding>
            <Insets bottom="30" left="40" right="40" top="50" />
         </padding>

         <Label style="-fx-text-fill: #8B1E1E; -fx-font-weight: bold;" text="Cadastro do Gerente">
            <font>
               <Font size="26" />
            </font>
         </Label>

         <Label style="-fx-text-fill: #666666;" text="Preencha os dados do gerente responsável pelo restaurante.">
            <font>
               <Font size="15" />
            </font>
         </Label>

         <VBox spacing="5">
            <Label text="Nome do gerente" />
            <TextField fx:id="nomeGerente" prefWidth="720" promptText="Nome completo do gerente" />
         </VBox>

         <HBox spacing="20">
            <VBox spacing="5">
               <Label text="Email do gerente" />
               <TextField fx:id="emailGerente" prefWidth="350" promptText="email@exemplo.com" />
            </VBox>

            <VBox spacing="5">
               <Label text="Senha do gerente" />
               <PasswordField fx:id="senhaGerente" prefWidth="350" promptText="Mínimo 8 caracteres" />
            </VBox>
         </HBox>

         <VBox spacing="5">
            <Label text="CPF do gerente" />
            <TextField fx:id="cpfGerente" prefWidth="720" promptText="000.000.000-00" />
         </VBox>

         <HBox alignment="CENTER_RIGHT" prefWidth="720" spacing="20">
            <Button fx:id="selecionarLogoTipo" mnemonicParsing="false" onAction="#selecionarLogo" prefHeight="31.0" prefWidth="132.0" text="Selecionar Logo" textFill="#892214">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>

            <Button fx:id="salvarRestaurante" onAction="#salvarORestaurante" prefHeight="40" prefWidth="140" style="-fx-background-color: #34D399; -fx-text-fill: white; -fx-font-weight: bold;" text="Salvar" />
         </HBox>
      </VBox>
   </center>
</BorderPane>
