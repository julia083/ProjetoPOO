<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #D1FAE5;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifpb.ads.foodjava.controller.cliente.CarrinhoController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="18.0" style="-fx-background-color: #34D399;" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="38.0" right="38.0" />
            </padding>
            <children>
                <Label text="FoodJava" textFill="WHITE">
                    <font>
                        <Font name="Times New Roman Bold" size="30.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="voltarCardapioButton" mnemonicParsing="false" onAction="#voltarCardapio" style="-fx-background-color: transparent; -fx-border-color: #0F5132; -fx-text-fill: #0F5132;" text="Voltar ao Cardapio">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor>
                </Button>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>
            <children>
                <Label alignment="CENTER" text="MEU CARRINHO" textFill="#962828">
                    <font>
                        <Font name="Times New Roman Bold" size="28.0" />
                    </font>
                </Label>

                <Separator prefWidth="200.0" />

                <ListView fx:id="listaCarrinho" prefHeight="350.0" />

                <HBox alignment="CENTER_RIGHT" spacing="30.0">
                    <children>
                        <Label text="Total do Pedido:" textFill="#4B5563">
                            <font>
                                <Font name="Times New Roman Bold" size="16.0" />
                            </font>
                        </Label>
                        <Label fx:id="totalLabel" text="R$ 0,00" textFill="#0D6609">
                            <font>
                                <Font name="Times New Roman Bold" size="22.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <Separator />

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <!-- Botão Remover Item (novo) -->
                        <Button fx:id="removerItemButton" mnemonicParsing="false" onAction="#removerItemSelecionado" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #FCA5A5; -fx-text-fill: #7F1D1D; -fx-font-weight: bold;" text="Remover Item">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>

                        <Button fx:id="limparCarrinhoButton" mnemonicParsing="false" onAction="#limparCarrinho" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #FDE68A; -fx-text-fill: #92400E; -fx-font-weight: bold;" text="Limpar Carrinho">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>

                        <Button fx:id="confirmarPedidoButton" mnemonicParsing="false" onAction="#confirmarPedido" prefHeight="44.0" prefWidth="200.0" style="-fx-background-color: #34D399; -fx-text-fill: #064E3B; -fx-font-weight: bold;" text="Confirmar Pedido">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                    </children>
                </HBox>

                <Label alignment="CENTER" text="Apos confirmar, o pedido nao podera ser alterado" textFill="#962828">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </center>
</BorderPane>

